{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "dist-desktop",
    "rootDir": "desktop",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["node"]
  },
  "include": ["desktop/**/*"],
  "exclude": [
    "desktop/scripts/**/*.mjs",
    "desktop/preload.ts",
    "desktop/src/premium/**"
  ]
}
